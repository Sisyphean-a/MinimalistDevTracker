{
  "name": "minimalist-dev-tracker",
  "displayName": "Minimalist Dev Tracker",
  "description": "Privacy-first local coding activity tracker",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sisyphean-a/MinimalistDevTracker.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "minimalTracker.openDailyReport",
        "title": "Minimal Tracker: Open Daily Report"
      }
    ],
    "configuration": {
      "title": "Minimalist Dev Tracker",
      "properties": {
        "minimalTracker.trackedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Absolute root repository paths to track"
        },
        "minimalTracker.fileWatch.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns (relative to tracked roots) to exclude from file activity watcher"
        },
        "minimalTracker.flushBeforeReport": {
          "type": "boolean",
          "default": true,
          "description": "Flush active tracking sessions before opening daily report"
        }
      }
    }
  },
  "scripts": {
    "test": "node test/run-tests.js",
    "compile": "echo compile-skipped"
  }
}
